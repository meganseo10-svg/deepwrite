# DEEPWRITE 환경변수 템플릿. 실제 값은 .env.local 에 넣으세요 (git 미추적).

# ── Supabase (deepread 와 별도 프로젝트 권장) ──
# Supabase 대시보드 → Project Settings → API 에서 복사
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=        # 서버 전용 (절대 클라이언트 노출 금지)

# ── Anthropic ──
ANTHROPIC_API_KEY=
# 모델 분리 (02 §5)
ANTHROPIC_MODEL_HEAVY=claude-opus-4-8   # 진단·리라이트·3톤·역번역 (고품질)
ANTHROPIC_MODEL_LIGHT=claude-haiku-4-5  # 라이브 힌트 (경량·저지연)

# ── 앱 / 생태계 ──
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEEPREAD_URL=         # deepread 배포 URL (헤더 딥링크)

# ── 결제 (T14) ──
TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=
